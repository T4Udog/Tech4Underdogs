{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/faq/layout,_N_T_/faq/page,_N_T_/faq"},"segmentPaths":["/_tree","/_full","/faq/__PAGE__","/faq","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=%2Fimages%2FTech-4-Underdogs-logo.png&amp;w=256&amp;q=75 1x, /_next/image?url=%2Fimages%2FTech-4-Underdogs-logo.png&amp;w=384&amp;q=75 2x\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=%2Fimages%2FArchie-FAQ.png&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fimages%2FArchie-FAQ.png&amp;w=1920&amp;q=75 2x\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0sa1u0rc1hzk..css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/13-yp3opu.wcn.js\"/><script src=\"/_next/static/chunks/0m_~xmh1tz_.k.js\" async=\"\"></script><script src=\"/_next/static/chunks/0m58q2exkjk_h.js\" async=\"\"></script><script src=\"/_next/static/chunks/0go48hnc0zwo..js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-147o_mzgf1hih.js\" async=\"\"></script><script src=\"/_next/static/chunks/118bchv4m662w.js\" async=\"\"></script><script src=\"/_next/static/chunks/10ncx8p1uu20r.js\" async=\"\"></script><script src=\"/_next/static/chunks/0ifrto9swfs7l.js\" async=\"\"></script><title>FAQ | Tech 4 Underdogs</title><meta name=\"description\" content=\"Straightforward answers about IT support pricing, local SEO timelines, website ownership, and Google Ads management for small businesses.\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link rel=\"icon\" href=\"/images/cropped-Asset-16T4U.png\"/><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body><div hidden=\