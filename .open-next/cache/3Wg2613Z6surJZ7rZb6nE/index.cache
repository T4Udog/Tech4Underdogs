nge transition-colors\" href=\"/faq\">FAQ</a></li><li><a class=\"font-exo font-bold text-xs tracking-[0.18em] uppercase text-navy/70 hover:text-orange transition-colors\" href=\"/contact\">Contact</a></li></ul><a class=\"btn btn-primary btn-sm\" href=\"/contact\">Get Started <span aria-hidden=\"true\">✦</span></a></div><button type=\"button\" aria-label=\"Open menu\" aria-expanded=\"false\" aria-controls=\"mobile-menu\" class=\"md:hidden w-11 h-11 flex flex-col items-center justify-center gap-1.5 cursor-pointer\"><span class=\"block w-6 h-0.5 bg-navy transition-all \" aria-hidden=\"true\"></span><span class=\"block w-6 h-0.5 bg-navy transition-all \" aria-hidden=\"true\"></span><span class=\"block w-6 h-0.5 bg-navy transition-all \" aria-hidden=\"true\"></span></button></nav><div id=\"mobile-menu\" class=\"md:hidden overflow-hidden transition-[max-height] duration-300 ease-out border-t border-navy/10 max-h-0\"><ul class=\"flex flex-col py-2 px-6 bg-cream\"><li><a class=\"block py-4 font-exo font-bold text-sm tracking-[0.18em] uppercase text-navy hover:text-orange transition-colors border-b border-navy/5\" href=\"/\">Home</a></li><li><a class=\"block py-4 font-exo font-bold text-sm tracking-[0.18em] uppercase text-navy hover:text-orange transition-colors border-b border-navy/5\" href=\"/about\">About</a></li><li class=\"border-b border-navy/5\"><button type=\"button\" aria-expanded=\"false\" class=\"w-full py-4 font-exo font-bold text-sm tracking-[0.18em] uppercase text-navy hover:text-orange transition-colors flex items-center justify-between cursor-pointer\"><span>Services</span><svg width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" class=\"transition-transform duration-200 \"><polyline points=\"6 9 12 15 18 9\"></polyline></svg></button><div class=\"overflow-hidden transition-[max-height] duration-300 ease-out max-h-0\"><ul class=\"pb-3 pl-3 border-l-2 border-orange/30 ml-1\"><li><a class=\"block py-2.5 px-3 font-exo font-semibold text-[0.8rem] tracking-[0.12em] uppercase text-navy/75 hover:text-orange transition-colors\" href=\"/services/it-support\">IT Support &amp; Security</a></li><li><a class=\"block py-2.5 px-3 font-exo font-semibold text-[0.8rem] tracking-[0.12em] uppercase text-navy/75 hover:text-orange transition-colors\" href=\"/services/web-design\">Web Design &amp; Hosting</a></li><li><a class=\"block py-2.5 px-3 font-exo font-semibold text-[0.8rem] tracking-[0.12em] uppercase text-navy/75 hover:text-orange transition-colors\" href=\"/services/marketing\">Online Marketing</a></li></ul></div></li><li><a class=\"block py-4 font-exo font-bold text-sm tracking-[0.18em] uppercase text-navy hover:text-orange transition-colors border-b border-navy/5\" href=\"/pricing\">Pricing</a></li><li><a class=\"block py-4 font-exo font-bold text-sm tracking-[0.18em] uppercase text-navy hover:text-orange transition-colors border-b border-navy/5\" href=\"/scorecard\">Scorecard</a></li><li><a class=\"block py-4 font-exo font-bold text-sm tracking-[0.18em] uppercase text-navy hover:text-orange transition-colors border-b border-navy/5\" href=\"/faq\">FAQ</a></li><li><a class=\"block py-4 font-exo font-bold text-sm tracking-[0.18em] uppercase text-navy hover:text-orange transition-colors border-b border-navy/5\" href=\"/contact\">Contact</a></li><li class=\"py-4\"><a class=\"btn btn-primary w-full justify-center\" href=\"/contact\">Get Started <span aria-hidden=\"true\">✦</span></a></li></ul></div></header><main class=\"font-rajdhani\"><section class=\"bg-cream overflow-hidden\"><div class=\"section-container section-y\"><div class=\"hero-layout\"><div class=\"flex flex-col pt-2 w-full lg:max-w-[680px]\"><p class=\"eyebrow mb-5\"><span class=\"eyebrow-mark\">✺</span>Never underestimate an underdog</p><h1 class=\"h-section text-navy mb-6 break-words\">You&#x27;ve built<br class=\"hidden lg:inline\"/> <!-- -->something<!-- --> <span class=\"italic text-outlined-navy\">real.</span><br class=\"hidden lg:inline\"/> <span class=\"italic\">It&#x27;s time your tech</span><br class=\"hidden lg:inline\"/> <span class=\"italic\">had<!-- --> </span><span class=\"italic text-orange\">your back.</span></h1><div class=\"lg:hidden flex justify-center mb-8\"><img alt=\"Archie, the Tech 4 Underdogs mascot, ready for work\" width=\"560\" height=\"620\" decoding=\"async\" data-nimg=\"1\" class=\"w-full max-w-[280px] sm:max-w-[340px] h-auto object-contain\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2FArchie-Toolbelt-e1773949293728.png&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fimages%2FArchie-Toolbelt-e1773949293728.png&amp;w=1200&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2FArchie-Toolbelt-e1773949293728.png&amp;w=1200&amp;q=75\"/></div><p class=\"body-text lg:max-w-[440px] mb-9 text-[1.05rem]\">Tech 4 Underdogs provides reliable, affordable IT, websites, and online marketing for small, local businesses — built for the ones doing serious work when every decision matters.</p><div class=\"flex flex-col sm:flex-row sm:flex-wrap gap-3 mb-6\"><a class=\"btn btn-primary  justify-center sm:justify-start\" href=\"/contact\">Talk to a Real Person<!-- --> <span aria-hidden=\"true\">✦</span></a><a class=\"btn btn-secondary  justify-center sm:justify-start\" href=\"#services\">See How We Help<!-- --> <span aria-hidden=\"true\">✦</span></a></div><p class=\"tagline text-navy\">Built tough.<!-- --> <span class=\"italic text-orange\">Still standing.</span></p></div><div class=\"hidden lg:flex flex-col items-end lg:w-[400px] xl:w-[460px] self-center relative\"><div class=\"relative z-10 w-full\"><img alt=\"Archie, the Tech 4 Underdogs mascot, ready for work\" width=\"560\" height=\"620\" decoding=\"async\" data-nimg=\"1\" class=\"w-full h-auto object-contain\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2FArchie-Toolbelt-e1773949293728.png&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fimages%2FArchie-Toolbelt-e1773949293728.png&amp;w=1200&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2FArchie-Toolbelt-e1773949293728.png&amp;w=1200&amp;q=75\"/></div><div class=\"absolute top-[55%] -left-40 z-0 bg-cream border border-navy/15 rounded-2xl shadow-lg px-4 py-3 max-w-[260px]\"><p class=\"font-exo font-extrabold text-[0.65rem] tracking-[0.22em] uppercase text-navy/70 mb-1.5\"><span class=\"text-orange font-black\">+</span> Meet Archie</p><p class=\"font-exo font-medium text-[0.78rem] text-navy/75 leading-[1.6]\">He built his business from scratch, handles everything himself, and is done letting his tech slow him down.<!-- --> <em class=\"font-semibold\">Sound familiar?</em></p><span class=\"absolute top-5 -right-2 w-0 h-0\" style=\"border-top:6px solid transparent;border-bottom:6px solid transparent;border-left:6px solid var(--color-cream)\" aria-hidden=\"true\"></span></div></div></div></div></section><section class=\"bg-navy overflow-hidden\"><div class=\"section-container pt-10\"><div class=\"grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-white/10 border-b border-white/10 pb-8\"><div class=\"flex items-center justify-center gap-3 py-4 sm:py-5 px-6\"><div class=\"text-white/50 flex-shrink-0\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.75\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"></path><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"></path></svg></div><span class=\"font-exo font-semibold text-white text-xs tracking-[0.18em] uppercase\">Real people. No call centers.</span></div><div class=\"flex items-center justify-center gap-3 py-4 sm:py-5 px-6\"><div class=\"text-white/50 flex-shrink-0\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.75\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><rect x=\"2\" y=\"3\" width=\"20\" height=\"14\" rx=\"2\"></rect><line x1=\"8\" y1=\"21\" x2=\"16\" y2=\"21\"></line><line x1=\"12\" y1=\"17\" x2=\"12\" y2=\"21\"></line></svg></div><span class=\"font-exo font-semibold text-white text-xs tracking-[0.18em] uppercase\">One partner. IT, Web &amp; Marketing.</span></div><div class=\"flex items-center justify-center gap-3 py-4 sm:py-5 px-6\"><div class=\"text-white/50 flex-shrink-0\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.75\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><polygon points=\"13 2 3 14 12 14 11 22 21 10 12 10 13 2\"></polygon></svg></div><span class=\"font-exo font-semibold text-white text-xs tracking-[0.18em] uppercase\">Fast to respond to your needs.</span></div></div></div><div class=\"section-container section-y\"><div class=\"grid lg:grid-cols-2 gap-10 lg:gap-16 items-center\"><div class=\"relative\"><img alt=\"Archie surrounded by tech problems — broken monitors, notifications, and a 404 error\" width=\"580\" height=\"540\" decoding=\"async\" data-nimg=\"1\" class=\"w-full h-auto object-contain\" style=\"color:transparent\" sizes=\"(min-width: 1024px) 580px, 100vw\" srcSet=\"/_next/image?url=%2Fimages%2FArchie-Computers.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2FArchie-Computers.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2FArchie-Computers.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2FArchie-Computers.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2FArchie-Computers.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2FArchie-Computers.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2FArchie-Computers.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2FArchie-Computers.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2FArchie-Computers.png&amp;w=3840&amp;q=75\"/></div><div><p class=\"eyebrow eyebrow-dark mb-5\"><span class=\"eyebrow-mark\">✺</span>We know your pain</p><h2 class=\"h-section mb-7\"><span class=\"text-white\">You handle </span><span class=\"italic text-white\">everything.</span><br/><span class=\"italic text-orange\">Your tech shouldn&#x27;t</span><br/><span class=\"italic text-orange\">be one more thing to wrestle.</span></h2><p class=\"body-text body-text-dark max-w-[440px] mb-8\">You open early, close late, and deal with problems as they come. But when your systems break, your website lags, or your marketing goes nowhere, you&#x27;re on your own — no IT department down the hall, no time to chase vendors. You just need things to work.</p><p class=\"tagline text-white\">Too many hats.<!-- --> <span class=\"italic text-orange\">Too many headaches.</span></p></div></div></div></section><section class=\"bg-cream overflow-hidden relative\"><div class=\"hidden md:block absolute right-0 top-0 text-orange font-eurostile leading-none select-none pointer-events-none\" style=\"font-size:clamp(8rem, 22vw, 22rem);line-height:0.85;opacity:0.9;right:-2rem;top:-1rem\" aria-hidden=\"true\">*</div><div class=\"section-container section-y relative z-10\"><div class=\"grid lg:grid-cols-2 gap-12 lg:gap-16 items-center\"><div><p class=\"eyebrow mb-5\"><span class=\"eyebrow-mark\">✺</span>Let us take the lead</p><h2 class=\"h-section text-navy mb-7\">That&#x27;s<!-- --> <span class=\"italic text-orange\">exactly</span><br/>why<!-- --> <span class=\"italic text-navy\">we exist.</span></h2><p class=\"body-text max-w-[480px] mb-5\">Tech 4 Underdogs was built for small businesses that have been burned, overlooked, or priced out by companies that were never really built for them. We act as your behind-the-scenes partner — keeping your technology quiet, your website steady, and your local presence working the way it should.</p><p class=\"font-exo font-bold text-navy text-[1rem] leading-[1.65] max-w-[480px] mb-9\">No jargon. No runaround. Just a reliable team that already has its eyes on your business.</p><p class=\"tagline text-navy\">Calm. Capable.<!-- --> <span class=\"italic text-orange\">On your side.</span></p></div><div class=\"flex justify-center lg:justify-end\"><img alt=\"Archie calm and capable at his desk\" loading=\"lazy\" width=\"520\" height=\"520\" decoding=\"async\" data-nimg=\"1\" class=\"w-full max-w-[500px] h-auto object-contain\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2FArchie-Capable.png&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fimages%2FArchie-Capable.png&amp;w=1080&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2FArchie-Capable.png&amp;w=1080&amp;q=75\"/></div></div></div></section><section id=\"services\" class=\"relative overflow-hidden scroll-mt-20 bg-teal-gradient\"><div class=\"section-container section-y relative z-10\"><div class=\"grid lg:grid-cols-[1fr_1fr] gap-8 lg:gap-12 lg:items-end mb-10 lg:mb-12\"><div><p class=\"eyebrow eyebrow-dark mb-4\"><span class=\"eyebrow-mark\">✺</span>The solution</p><h2 class=\"h-section\"><span class=\"text-white\">One partner. </span><span class=\"italic text-orange\">Three things</span> <span class=\"italic text-white\">done right.</span></h2></div><p class=\"body-text body-text-dark max-w-[560px]\">Instead of juggling vendors and chasing callbacks, you get one accountable team that understands your business — and stays with you for the long haul.</p></div><div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 mb-14\"><div class=\"rounded-2xl p-8 flex flex-col items-center text-center border border-white/10\" style=\"background:rgba(255,255,255,0.08)\"><div class=\"mb-6 w-16 h-16 flex items-center justify-center\"><img alt=\"\" aria-hidden=\"true\" loading=\"lazy\" width=\"64\" height=\"64\" decoding=\"async\" data-nimg=\"1\" class=\"w-full h-full object-contain\" style=\"color:transparent;filter:brightness(0) invert(1)\" src=\"/images/Asset-1T4U.svg\"/></div><h3 class=\"font-eurostile text-white tracking-wide mb-4\" style=\"font-size:1.35rem;line-height:1.15;text-transform:uppercase\">IT Support &amp; Security</h3><p class=\"font-exo font-medium text-white/80 text-[0.95rem] leading-[1.7] mb-6 flex-1\">Your systems stay monitored, protected, and supported. When something goes wrong, you reach a real person — not a ticket queue.</p><a href=\"/services/it-support\" class=\"btn btn-primary btn-sm mt-auto w-full justify-center\">Learn More <span aria-hidden=\"true\">✦</span></a></div><div class=\"rounded-2xl p-8 flex flex-col items-center text-center border border-white/10\" style=\"background:rgba(255,255,255,0.08)\"><div class=\"mb-6 w-16 h-16 flex items-center justify-center\"><img alt=\"\" aria-hidden=\"true\" loading=\"lazy\" width=\"64\" height=\"64\" decoding=\"async\" data-nimg=\"1\" class=\"w-full h-full object-contain\" style=\"color:transparent;filter:brightness(0) invert(1)\" src=\"/images/Asset-2T4U.svg\"/></div><h3 class=\"font-eurostile text-white tracking-wide mb-4\" style=\"font-size:1.35rem;line-height:1.15;text-transform:uppercase\">Web Design &amp; Hosting</h3><p class=\"font-exo font-medium text-white/80 text-[0.95rem] leading-[1.7] mb-6 flex-1\">A professional website that loads fast, looks right, and stays online. Built for your business, maintained by us.</p><a href=\"/services/web-design\" class=\"btn btn-primary btn-sm mt-auto w-full justify-center\">Learn More <span aria-hidden=\"true\">✦</span></a></div><div class=\"rounded-2xl p-8 flex flex-col items-center text-center border border-white/10\" style=\"background:rgba(255,255,255,0.08)\"><div class=\"mb-6 w-16 h-16 flex items-center justify-center\"><img alt=\"\" aria-hidden=\"true\" loading=\"lazy\" width=\"64\" height=\"64\" decoding=\"async\" data-nimg=\"1\" class=\"w-full h-full object-contain\" style=\"color:transparent;filter:brightness(0) invert(1)\" src=\"/images/Asset-3T4U.svg\"/></div><h3 class=\"font-eurostile text-white tracking-wide mb-4\" style=\"font-size:1.35rem;line-height:1.15;text-transform:uppercase\">Marketing &amp; SEO</h3><p class=\"font-exo font-medium text-white/80 text-[0.95rem] leading-[1.7] mb-6 flex-1\">Local SEO and Google Ads that help real customers find you — honest, straightforward, and built to earn their keep.</p><a href=\"/services/marketing\" class=\"btn btn-primary btn-sm mt-auto w-full justify-center\">Learn More <span aria-hidden=\"true\">✦</span></a></div></div><div class=\"bg-white/10 border border-white/15 rounded-2xl px-6 py-5 lg:px-8 lg:py-6 mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-center sm:text-left\"><p class=\"font-eurostile uppercase text-white text-[1.15rem] lg:text-[1.35rem] tracking-wide leading-tight text-balance\"><span class=\"italic text-orange\">$35/user/mo</span> <!-- -->— month-to-month, no long-term contracts.</p><a class=\"btn btn-sm bg-white text-navy hover:bg-cream flex-shrink-0 justify-center\" href=\"/pricing\">See Pricing <span aria-hidden=\"true\">✦</span></a></div><p class=\"font-exo font-semibold text-white/50 text-xs tracking-[0.18em] uppercase text-center flex items-center justify-center gap-2\"><span class=\"text-orange/60\">✺</span>No unnecessary extras. Just the basics done right, by people who know what&#x27;s actually at stake for you.</p></div></section><section class=\"bg-white overflow-hidden\"><div class=\"section-container section-y\"><div class=\"grid lg:grid-cols-2 gap-10 lg:gap-16 items-center\"><div class=\"flex justify-center lg:justify-start\"><img alt=\"Archie relaxed at his desk — technology no longer a problem\" loading=\"lazy\" width=\"600\" height=\"500\" decoding=\"async\" data-nimg=\"1\" class=\"w-full max-w-[560px] h-auto object-contain\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2FArchie-On-Your-Side.png&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fimages%2FArchie-On-Your-Side.png&amp;w=1200&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2FArchie-On-Your-Side.png&amp;w=1200&amp;q=75\"/></div><div><p class=\"eyebrow mb-5\"><span class=\"eyebrow-mark\">✺</span>We let a dog have its day</p><h2 class=\"h-section text-navy mb-7\">What happens when<br/><span class=\"italic text-orange\">technology</span> <!-- -->stops<br/>being the<!-- --> <span class=\"italic text-navy\">problem.</span></h2><p class=\"body-text max-w-[460px] mb-8\">With Tech 4 Underdogs by his side, Archie can focus on what he does best every day. No more worrying about falling behind the pack or losing his bone — Archie now runs his business knowing his technology and marketing needs are being handled right, at a price he can afford.</p><p class=\"tagline text-navy\">Steady. Secure.<!-- --> <span class=\"italic text-orange\">Back to Business.</span></p></div></div></div></section><section id=\"portfolio\" class=\"bg-cream overflow-hidden\"><div class=\"section-container section-y\"><div class=\"flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12 lg:mb-16\"><div><p class=\"eyebrow mb-5\"><span class=\"eyebrow-mark\">✺</span>Recent work</p><h2 class=\"h-section text-navy text-balance\"><span class=\"italic text-orange\">Port</span>folio</h2><p class=\"body-text max-w-[560px] mt-4 text-pretty\">We&#x27;ve helped local business owners get their tech working for them — not against them. From websites to IT support, here&#x27;s a sample of what we&#x27;ve built together.</p></div><a class=\"btn btn-primary flex-shrink-0 self-start sm:self-auto\" href=\"/contact\">Talk to a Real Person<!-- --> <span aria-hidden=\"true\">✦</span></a></div><ul class=\"grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8\"><li><article class=\"group bg-white border border-navy/10 rounded-2xl overflow-hidden h-full flex flex-col transition-all duration-200 hover:border-orange/40 hover:shadow-xl hover:-translate-y-1\"><div class=\"aspect-[4/3] overflow-hidden bg-navy/5\"><img alt=\"[Client Name]\" loading=\"lazy\" width=\"800\" height=\"600\" decoding=\"async\" data-nimg=\"1\" clas