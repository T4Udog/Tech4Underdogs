{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/services/layout,_N_T_/services/marketing/layout,_N_T_/services/marketing/page,_N_T_/services/marketing"},"segmentPaths":["/_tree","/_full","/services/marketing/__PAGE__","/services/marketing","/services","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=%2Fimages%2FTech-4-Underdogs-logo.png&amp;w=256&amp;q=75 1x, /_next/image?url=%2Fimages%2FTech-4-Underdogs-logo.png&amp;w=384&amp;q=75 2x\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=%2Fimages%2FArchie-Local-SEO.png&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fimages%2FArchie-Local-SEO.png&amp;w=1920&amp;q=75 2x\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0sa1u0rc1hzk..css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/13-yp3opu.wcn.js\"/><script src=\"/_next/static/chunks/0m_~xmh1tz_.k.js\" async=\"\"></script><script src=\"/_next/static/chunks/0m58q2exkjk_h.js\" async=\"\"></script><script src=\"/_next/static/chunks/0go48hnc0zwo..js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-147o_mzgf1hih.js\" async=\"\"></script><script src=\"/_next/static/chunks/118bchv4m662w.js\" async=\"\"></script><script src=\"/_next/static/chunks/10ncx8p1uu20r.js\" async=\"\"></script><script src=\"/_next/static/chunks/0g7j8a1sf-h~w.js\" async=\"\"></script><title>Online Marketing | Tech 4 Underdogs</title><meta name=\"description\" content=\"Local SEO, Google Ads, and Google Business Profile management for small, local businesses. Honest pricing, plain-language reporting, real results.\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link rel=\"icon\" hr